{
  "name": "scalable-ecommerce-backend",
  "version": "1.0.0",
  "private": true,
  "description": "Microservice-based e-commerce backend with REST and GraphQL in Express.js and TypeScript.",
  "main": "dist/services/api-gateway/index.js",
  "scripts": {
    "dev:gateway": "tsx watch services/api-gateway/index.ts",
    "dev:catalog": "tsx watch services/catalog-service/index.ts",
    "dev:cart": "tsx watch services/cart-service/index.ts",
    "dev:orders": "tsx watch services/order-service/index.ts",
    "dev:payments": "tsx watch services/payment-service/index.ts",
    "dev:inventory": "tsx watch services/inventory-service/index.ts",
    "dev:users": "tsx watch services/user-service/index.ts",
    "build": "tsc -p tsconfig.json",
    "start:gateway": "node dist/services/api-gateway/index.js",
    "start:catalog": "node dist/services/catalog-service/index.js",
    "start:cart": "node dist/services/cart-service/index.js",
    "start:orders": "node dist/services/order-service/index.js",
    "start:payments": "node dist/services/payment-service/index.js",
    "start:inventory": "node dist/services/inventory-service/index.js",
    "start:users": "node dist/services/user-service/index.js",
    "seed": "tsx scripts/seed.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@elastic/elasticsearch": "^8.19.1",
    "amqplib": "^0.10.9",
    "bcryptjs": "^3.0.2",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^5.1.0",
    "express-validator": "^7.2.1",
    "graphql": "^16.11.0",
    "helmet": "^8.1.0",
    "ioredis": "^5.8.1",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.18.0",
    "morgan": "^1.10.1",
    "stripe": "^18.5.0"
  },
  "devDependencies": {
    "@types/amqplib": "^0.10.8",
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.10",
    "@types/node": "^24.9.1",
    "@types/supertest": "^6.0.3",
    "supertest": "^7.1.4",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}